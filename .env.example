# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mtracker
POSTGRES_PASSWORD=mtracker_secret
POSTGRES_DB=mtracker

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
JWT_SECRET=change_me_to_a_long_random_string_in_production

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# You need a "Web application" client ID for server-side token verification
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Mobile app (Expo) ─────────────────────────────────────────────────────────
# These go in apps/mobile/.env (not tracked by git)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080       <- Android emulator
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8080    <- physical device (your machine's LAN IP)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_oauth_client_id
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_oauth_client_id
